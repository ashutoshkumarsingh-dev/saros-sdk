{
  "name": "@saros-finance/sdk",
  "version": "2.4.0",
  "description": "Saros swap - A DeFi Super-Network Built on Solana",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "publish": "npm publish --access public",
    "start": "parcel example/index.html",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src/**/*.js",
    "type-check": "tsc --noEmit --allowJs --checkJs",
    "build": "parcel build src/index.js --out-dir dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coin98/saros-sdk.git"
  },
  "keywords": [
    "Saros",
    "Swap",
    "solana",
    "sdk",
    "crypto",
    "farm",
    "stake",
    "finance"
  ],
  "author": "support@coin98.com",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/coin98/saros-sdk/issues"
  },
  "homepage": "https://github.com/coin98/saros-sdk#readme",
  "dependencies": {
    "@project-serum/anchor": "^0.25.0-beta.1",
    "@project-serum/borsh": "^0.2.3",
    "@project-serum/serum": "^0.13.61",
    "@solana/spl-token": "^0.1.8",
    "@solana/web3.js": "^1.31.0",
    "bigdecimal": "^0.6.1",
    "bn.js": "^5.2.0",
    "bs58": "^4.0.1",
    "buffer-layout": "^1.2.2",
    "crypto-js": "^4.1.1",
    "graphql": "^16.0.1",
    "graphql-request": "^3.6.1",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "eslint": "^8.6.0",
    "parcel": "^2.0.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.0.0",
    "fast-check": "^3.0.0"
  },
  "jest": {
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
